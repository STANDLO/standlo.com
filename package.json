{
  "name": "standlo.com",
  "version": "0.1.15",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && rm -rf node_modules/.cache && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "validate": "rm -rf node_modules && npm i && npm run lint && npm run build && npm audit",
    "emulator": "npm run build --prefix functions && firebase emulators:start",
    "cloud": "npx tsx scripts/deploy.ts",
    "cloud:firebase": "node scripts/DeployFirebase.mjs",
    "cloud:validate": "npm run pentest:local && npx tsx scripts/deploy.ts --validate-only",
    "pentest:local": "node scripts/pentest.mjs --target http://localhost:3000",
    "pentest:prod": "node scripts/pentest.mjs --target https://standlo.com"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@react-three/xr": "^6.6.29",
    "@types/three": "^0.183.1",
    "@types/uuid": "^10.0.0",
    "@use-gesture/react": "^10.3.1",
    "@vis.gl/react-google-maps": "^1.7.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "firebase-functions": "^7.0.5",
    "leva": "^0.10.1",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-firebase-auth-edge": "^1.11.5",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "three-mesh-bvh": "^0.9.8",
    "tunnel-rat": "^0.1.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@swc/helpers": "^0.5.19",
    "@tailwindcss/postcss": "^4",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axios": "^1.13.5",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "picomatch": "^4.0.3",
    "proxy-from-env": "^2.0.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "@eslint/config-array": "^0.19.0",
    "next-firebase-auth-edge": {
      "next": "$next"
    },
    "hono": "^4.12.4",
    "@hono/node-server": "^1.19.10",
    "express-rate-limit": "^8.2.2",
    "@tootallnate/once": "^3.0.1",
    "node-domexception": "^2.0.2",
    "@fortawesome/react-fontawesome": "^3.2.0"
  }
