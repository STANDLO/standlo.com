{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@core/*": [
        "./core/*"
      ],
      "@app/*": [
        "./src/app/*"
      ],
      "@/lib/*": [
        "./src/lib/*"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ],
      "@/components/*": [
        "./src/components/*"
      ],
      "@schemas/*": [
        "./schemas/*"
      ],
      "@ui/*": [
        "./src/app/components/ui/*"
      ],
      "@functions/*": [
        "./functions/*"
      ],
      "@admin/*": [
        "./admin/*"
      ],
      "@logs/*": [
        "./logs/*"
      ],
      "@scripts/*": [
        "./scripts/*"
      ],
      "@tmp/*": [
        "./tmp/*"
      ],
      "@seed/*": [
        "./seed/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "admin",
    "admin/**/*",
    "functions",
    "functions/**/*",
    "scripts",
    "scripts/**/*",
    "seed",
    "seed/**/*",
    "exports",
    "exports/**/*",
    "backup",
    "backup/**/*",
    "tmp",
    "tmp/**/*"
  ]
}